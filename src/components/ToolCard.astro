---
export interface Props {
  name: string;
  description: string;
  category: string;
  rating: number;
  image?: string;
  affiliateUrl?: string;
  features?: string[];
  pricing?: string;
}

const {
  name,
  description,
  category,
  rating,
  affiliateUrl,
  features = [],
  pricing = 'Free trial available'
} = Astro.props;
---

<article class="group relative bg-[#16161f] rounded-2xl border border-white/10 overflow-hidden hover:border-[#00ffc8]/40 transition-all duration-300">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00ffc8]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

  <div class="p-6">
    <!-- Header -->
    <div class="flex items-start justify-between mb-4">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-[#00ffc8]/10 border border-[#00ffc8]/30 rounded-full text-[#00ffc8] text-xs font-medium">
        {category}
      </span>
      <div class="flex items-center gap-1">
        <span class="text-[#ffb800] text-sm">★</span>
        <span class="text-white font-medium text-sm">{rating}</span>
      </div>
    </div>

    <!-- Title -->
    <h3 class="font-display font-semibold text-xl text-white mb-2 group-hover:text-[#00ffc8] transition-colors">
      {name}
    </h3>

    <!-- Description -->
    <p class="text-gray-400 text-sm mb-4 leading-relaxed line-clamp-2">
      {description}
    </p>

    <!-- Features -->
    <div class="flex flex-wrap gap-2 mb-6">
      {features.slice(0, 3).map((feature) => (
        <span class="text-xs text-gray-400 bg-[#0f0f16] px-2.5 py-1 rounded-md border border-white/5">
          {feature}
        </span>
      ))}
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between pt-4 border-t border-white/10">
      <span class="text-sm text-gray-400">{pricing}</span>
      <a
        href={affiliateUrl || '#'}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="inline-flex items-center gap-1.5 text-[#00ffc8] hover:text-[#33ffcf] font-medium text-sm transition-colors group/btn"
      >
        View Details
        <svg class="w-4 h-4 group-hover/btn:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
