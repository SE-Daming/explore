---
export interface Props {
  title: string;
  excerpt: string;
  date: string;
  author?: string;
  category: string;
  readTime?: string;
  slug: string;
}

const { title, excerpt, date, author = "AI Tools Hub", category, readTime = "5 min", slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
---

<article class="group relative bg-[#16161f] rounded-2xl border border-white/10 overflow-hidden hover:border-[#ffb800]/40 transition-all duration-300">
  <a href={`/reviews/${slug}`} class="block p-6">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-flex items-center px-3 py-1 bg-[#ffb800]/10 border border-[#ffb800]/30 rounded-full text-[#ffb800] text-xs font-medium">
        {category}
      </span>
      <span class="text-gray-500 text-xs">{readTime} read</span>
    </div>

    <!-- Title -->
    <h3 class="font-display font-semibold text-xl text-white mb-3 group-hover:text-[#ffb800] transition-colors leading-snug">
      {title}
    </h3>

    <!-- Excerpt -->
    <p class="text-gray-400 text-sm mb-4 leading-relaxed line-clamp-2">
      {excerpt}
    </p>

    <!-- Footer -->
    <div class="flex items-center justify-between pt-4 border-t border-white/10">
      <span class="text-sm text-gray-400">{author}</span>
      <time datetime={date} class="text-xs text-gray-500">{formattedDate}</time>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
