---
export interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url, description } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer nofollow"
  class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors"
>
  {title}
  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
  </svg>
</a>
{description && (
  <p class="text-xs text-gray-500 mt-2">{description}</p>
)}
