---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Discover the best AI tools for your workflow. Honest reviews, comparisons, and guides.", image = "/og-image.png" } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title} | AI Tools Hub</title>
    <meta name="title" content={`${title} | AI Tools Hub`} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | AI Tools Hub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | AI Tools Hub`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&family=Syne:wght@500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0a0a0f] text-white antialiased font-body">
    <!-- Noise texture overlay -->
    <div class="fixed inset-0 bg-noise opacity-[0.015] pointer-events-none z-50"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-40 bg-[#0a0a0f]/90 backdrop-blur-xl border-b border-white/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-9 h-9 bg-[#00ffc8]/20 rounded-lg flex items-center justify-center group-hover:bg-[#00ffc8]/30 transition-colors border border-[#00ffc8]/30">
              <span class="text-[#00ffc8] font-display font-bold text-sm">AI</span>
            </div>
            <span class="font-display font-bold text-lg tracking-tight">
              <span class="text-white">Tools</span><span class="text-[#00ffc8]">Hub</span>
            </span>
          </a>

          <div class="hidden md:flex items-center gap-8">
            <a href="/tools" class="text-sm text-gray-300 hover:text-[#00ffc8] transition-colors font-medium">Tools</a>
            <a href="/reviews" class="text-sm text-gray-300 hover:text-[#00ffc8] transition-colors font-medium">Reviews</a>
            <a href="/categories" class="text-sm text-gray-300 hover:text-[#00ffc8] transition-colors font-medium">Categories</a>
            <a href="/about" class="text-sm text-gray-300 hover:text-[#00ffc8] transition-colors font-medium">About</a>
          </div>

          <a href="/tools" class="bg-[#00ffc8] text-[#0a0a0f] hover:bg-[#33ffcf] px-5 py-2.5 rounded-lg font-display font-semibold text-sm transition-all">
            Browse Tools
          </a>
        </div>
      </div>
    </nav>

    <main class="relative z-10 pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative z-10 bg-[#0f0f16] border-t border-white/10 mt-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-[#00ffc8]/20 rounded-lg flex items-center justify-center border border-[#00ffc8]/30">
                <span class="text-[#00ffc8] font-display font-bold">AI</span>
              </div>
              <span class="font-display font-bold text-xl">
                <span class="text-white">Tools</span><span class="text-[#00ffc8]">Hub</span>
              </span>
            </div>
            <p class="text-gray-400 max-w-sm leading-relaxed">
              Your trusted source for AI tool reviews, comparisons, and guides. We help you find the right AI tools for your workflow.
            </p>
          </div>

          <div>
            <h4 class="font-display font-semibold text-white mb-4">Quick Links</h4>
            <ul class="space-y-3">
              <li><a href="/tools" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">All Tools</a></li>
              <li><a href="/reviews" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">Reviews</a></li>
              <li><a href="/categories" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">Categories</a></li>
              <li><a href="/about" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">About</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-display font-semibold text-white mb-4">Popular Categories</h4>
            <ul class="space-y-3">
              <li><a href="/categories/ai-writing" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">AI Writing</a></li>
              <li><a href="/categories/ai-image" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">AI Image</a></li>
              <li><a href="/categories/ai-code" class="text-gray-400 hover:text-[#00ffc8] transition-colors text-sm">AI Code</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-gray-500 text-sm">© {new Date().getFullYear()} AI Tools Hub. All rights reserved.</p>
          <p class="text-gray-600 text-xs">
            Disclosure: We may earn a commission when you purchase through our links.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  html {
    scroll-behavior: smooth;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #0f0f16;
  }
  ::-webkit-scrollbar-thumb {
    background: #2a2a3a;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #00ffc8;
  }

  /* Selection */
  ::selection {
    background: rgba(0, 255, 200, 0.3);
    color: #fff;
  }
</style>
